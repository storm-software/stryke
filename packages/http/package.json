  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/type-checks": "workspace:*",
    "@stryke/url": "workspace:*",
    "defu": "catalog:",
    "undici": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "undici-types": "catalog:"
  },
  "publishConfig": {
