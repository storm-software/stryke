    },
    "./fetch": {
      "import": "./dist/fetch.mjs",
      "require": "./dist/fetch.cjs"
    },
    "./fetch.test": {
      "import": "./dist/fetch.test.mjs",
      "require": "./dist/fetch.test.cjs"
    },
    "./format-data-uri": {
      "import": "./dist/format-data-uri.mjs",
