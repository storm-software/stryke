    "./index.test": {
      "import": "./dist/index.test.mjs",
      "require": "./dist/index.test.cjs"
    },
    "./parse-response": {
      "import": "./dist/parse-response.mjs",
      "require": "./dist/parse-response.cjs"
    },
    "./parse-response.test": {
      "import": "./dist/parse-response.test.mjs",
