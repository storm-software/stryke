{
  "name": "@stryke/http",
  "version": "0.12.87",
  "private": false,
  "description": "A package containing HTTP communication utilities used by Storm Software.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/http"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./fetch": {
      "import": "./dist/fetch.mjs",
      "require": "./dist/fetch.cjs"
    },
    "./format-data-uri": {
      "import": "./dist/format-data-uri.mjs",
      "require": "./dist/format-data-uri.cjs"
    },
    "./get-free-port": {
      "import": "./dist/get-free-port.mjs",
      "require": "./dist/get-free-port.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/type-checks": "workspace:*",
    "@stryke/url": "workspace:*",
    "defu": "catalog:",
    "mime-types": "catalog:",
    "ufo": "catalog:",
    "undici": "catalog:"
  },
  "devDependencies": {
    "@types/mime-types": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "undici-types": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
