{
  "name": "@stryke/crypto",
  "version": "0.6.5",
  "type": "module",
  "description": "A package containing cryptographic utilities used by Storm Software.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/crypto"
  },
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./index": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./neutral": {
      "require": {
        "type": "./dist/neutral.d.cts",
        "default": "./dist/neutral.cjs"
      },
      "import": {
        "type": "./dist/neutral.d.mts",
        "default": "./dist/neutral.mjs"
      },
      "default": {
        "type": "./dist/neutral.d.mts",
        "default": "./dist/neutral.mjs"
      }
    },
    "./node": {
      "require": {
        "type": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      },
      "import": {
        "type": "./dist/node.d.mts",
        "default": "./dist/node.mjs"
      },
      "default": {
        "type": "./dist/node.d.mts",
        "default": "./dist/node.mjs"
      }
    },
    "./cloudflare": {
      "require": {
        "type": "./dist/cloudflare.d.cts",
        "default": "./dist/cloudflare.cjs"
      },
      "import": {
        "type": "./dist/cloudflare.d.mts",
        "default": "./dist/cloudflare.mjs"
      },
      "default": {
        "type": "./dist/cloudflare.d.mts",
        "default": "./dist/cloudflare.mjs"
      }
    }
  },
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/convert": "workspace:*",
    "@stryke/json": "workspace:*",
    "@stryke/type-checks": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
