{
  "name": "@stryke/cookie",
  "version": "0.1.75",
  "private": false,
  "description": "A package containing HTTP Cookie utilities used by Storm Software.",
  "repository": "null//github.com/null/github.com/tree/main/packages/cookie",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./parse": {
      "import": "./dist/parse.mjs",
      "require": "./dist/parse.cjs"
    },
    "./split": {
      "import": "./dist/split.mjs",
      "require": "./dist/split.cjs"
    },
    "./stringify": {
      "import": "./dist/stringify.mjs",
      "require": "./dist/stringify.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/convert": "workspace:*",
    "@stryke/type-checks": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
