{
  "name": "@stryke/cookie",
  "version": "0.1.71",
  "private": false,
  "description": "A package containing HTTP Cookie utilities used by Storm Software.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/cookie"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./index.test": {
      "import": "./dist/index.test.mjs",
      "require": "./dist/index.test.cjs"
    },
    "./parse": {
      "import": "./dist/parse.mjs",
      "require": "./dist/parse.cjs"
    },
    "./parse.test": {
      "import": "./dist/parse.test.mjs",
      "require": "./dist/parse.test.cjs"
    },
    "./split": {
      "import": "./dist/split.mjs",
      "require": "./dist/split.cjs"
    },
    "./split.test": {
      "import": "./dist/split.test.mjs",
      "require": "./dist/split.test.cjs"
    },
    "./stringify": {
      "import": "./dist/stringify.mjs",
      "require": "./dist/stringify.cjs"
    },
    "./stringify.test": {
      "import": "./dist/stringify.test.mjs",
      "require": "./dist/stringify.test.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./types.test": {
      "import": "./dist/types.test.mjs",
      "require": "./dist/types.test.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/convert": "workspace:*",
    "@stryke/type-checks": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
