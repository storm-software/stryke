    },
    "./array": {
      "import": "./dist/array.mjs",
      "require": "./dist/array.cjs"
    },
    "./async": {
      "import": "./dist/async.mjs",
      "require": "./dist/async.cjs"
    },
    "./base": {
      "import": "./dist/base.mjs",
      "require": "./dist/base.cjs"
    },
    "./configuration": {
      "import": "./dist/configuration.mjs",
      "require": "./dist/configuration.cjs"
    },
    "./file": {
      "import": "./dist/file.mjs",
      "require": "./dist/file.cjs"
    },
    "./form": {
      "import": "./dist/form.mjs",
      "require": "./dist/form.cjs"
    },
    "./json": {
      "import": "./dist/json.mjs",
      "require": "./dist/json.cjs"
    },
    "./logic": {
      "import": "./dist/logic.mjs",
      "require": "./dist/logic.cjs"
    },
    "./messages": {
      "import": "./dist/messages.mjs",
      "require": "./dist/messages.cjs"
    },
    "./navigator": {
      "import": "./dist/navigator.mjs",
      "require": "./dist/navigator.cjs"
    },
    "./number": {
      "import": "./dist/number.mjs",
      "require": "./dist/number.cjs"
    },
    "./object": {
      "import": "./dist/object.mjs",
      "require": "./dist/object.cjs"
    },
    "./package-json": {
      "import": "./dist/package-json.mjs",
      "require": "./dist/package-json.cjs"
    },
    "./package-manager": {
      "import": "./dist/package-manager.mjs",
      "require": "./dist/package-manager.cjs"
    },
    "./string": {
      "import": "./dist/string.mjs",
      "require": "./dist/string.cjs"
    },
    "./system": {
      "import": "./dist/system.mjs",
      "require": "./dist/system.cjs"
    },
    "./tsconfig": {
      "import": "./dist/tsconfig.mjs",
      "require": "./dist/tsconfig.cjs"
    },
    "./user": {
      "import": "./dist/user.mjs",
      "require": "./dist/user.cjs"
    },
    "./validations": {
      "import": "./dist/validations.mjs",
      "require": "./dist/validations.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typings": "dist/index.d.mts",
  "files": ["dist/**/*"],
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
