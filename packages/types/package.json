{
  "name": "@stryke/types",
  "version": "0.12.14",
  "private": false,
  "description": "A package containing many base TypeScript type definitions that are shared across many projects.",
  "keywords": [
    "stryke",
    "typescript",
    "utilities",
    "storm-software",
    "storm",
    "sullivanpj"
  ],
  "homepage": "https://stormsoftware.com",
