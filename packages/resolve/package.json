{
  "name": "@stryke/resolve",
  "version": "0.0.9",
  "private": false,
  "description": "A package containing logic to resolve file contents from various sources.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/resolve"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./bundle": {
      "import": "./dist/bundle.mjs",
      "require": "./dist/bundle.cjs"
    },
    "./constants": {
      "import": "./dist/constants.mjs",
      "require": "./dist/constants.cjs"
    },
    "./helpers": {
      "import": "./dist/helpers.mjs",
      "require": "./dist/helpers.cjs"
    },
    "./load": {
      "import": "./dist/load.mjs",
      "require": "./dist/load.cjs"
    },
    "./regex": {
      "import": "./dist/regex.mjs",
      "require": "./dist/regex.cjs"
    },
    "./resolve": {
      "import": "./dist/resolve.mjs",
      "require": "./dist/resolve.cjs"
    },
    "./type-checks": {
      "import": "./dist/type-checks.mjs",
      "require": "./dist/type-checks.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/fs": "workspace:*",
    "@stryke/http": "workspace:*",
    "@stryke/path": "workspace:*",
    "@stryke/type-checks": "workspace:*",
    "@stryke/types": "workspace:*",
    "@stryke/url": "workspace:*",
    "defu": "catalog:",
    "esbuild": "catalog:",
    "jiti": "catalog:",
    "smol-toml": "catalog:",
    "typescript": "^6.0.3",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
