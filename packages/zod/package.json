{
  "name": "@stryke/zod",
  "version": "0.3.16",
  "private": false,
  "description": "A package containing helper utilities for working with zod schemas.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/zod"
  },
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./index": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./is-zod-type": {
      "require": {
        "type": "./dist/is-zod-type.d.cts",
        "default": "./dist/is-zod-type.cjs"
      },
      "import": {
        "type": "./dist/is-zod-type.d.mts",
        "default": "./dist/is-zod-type.mjs"
      },
      "default": {
        "type": "./dist/is-zod-type.d.mts",
        "default": "./dist/is-zod-type.mjs"
      }
    },
    "./schema": {
      "require": {
        "type": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      },
      "import": {
        "type": "./dist/schema.d.mts",
        "default": "./dist/schema.mjs"
      },
      "default": {
        "type": "./dist/schema.d.mts",
        "default": "./dist/schema.mjs"
      }
    },
    "./types": {
      "require": {
        "type": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      },
      "import": {
        "type": "./dist/types.d.mts",
        "default": "./dist/types.mjs"
      },
      "default": {
        "type": "./dist/types.d.mts",
        "default": "./dist/types.mjs"
      }
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/type-checks": "workspace:*",
    "zod-to-json-schema": "catalog:"
  },
  "devDependencies": {
    "@stryke/json": "workspace:*",
    "tsdown": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
