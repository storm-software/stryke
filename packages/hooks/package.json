{
  "name": "@stryke/hooks",
  "version": "0.4.91",
  "private": false,
  "description": "A package containing shared hooks that can be used in any React UI project",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/hooks"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./use-battery": {
      "import": "./dist/use-battery.mjs",
      "require": "./dist/use-battery.cjs"
    },
    "./use-callback-ref": {
      "import": "./dist/use-callback-ref.mjs",
      "require": "./dist/use-callback-ref.cjs"
    },
    "./use-callback-stable": {
      "import": "./dist/use-callback-stable.mjs",
      "require": "./dist/use-callback-stable.cjs"
    },
    "./use-click-away": {
      "import": "./dist/use-click-away.mjs",
      "require": "./dist/use-click-away.cjs"
    },
    "./use-compose-refs": {
      "import": "./dist/use-compose-refs.mjs",
      "require": "./dist/use-compose-refs.cjs"
    },
    "./use-copy-to-clipboard": {
      "import": "./dist/use-copy-to-clipboard.mjs",
      "require": "./dist/use-copy-to-clipboard.cjs"
    },
    "./use-debounce": {
      "import": "./dist/use-debounce.mjs",
      "require": "./dist/use-debounce.cjs"
    },
    "./use-did-finish-ssr": {
      "import": "./dist/use-did-finish-ssr.mjs",
      "require": "./dist/use-did-finish-ssr.cjs"
    },
    "./use-escape-keydown": {
      "import": "./dist/use-escape-keydown.mjs",
      "require": "./dist/use-escape-keydown.cjs"
    },
    "./use-event": {
      "import": "./dist/use-event.mjs",
      "require": "./dist/use-event.cjs"
    },
    "./use-hover": {
      "import": "./dist/use-hover.mjs",
      "require": "./dist/use-hover.cjs"
    },
    "./use-idle": {
      "import": "./dist/use-idle.mjs",
      "require": "./dist/use-idle.cjs"
    },
    "./use-isomorphic-layout-effect": {
      "import": "./dist/use-isomorphic-layout-effect.mjs",
      "require": "./dist/use-isomorphic-layout-effect.cjs"
    },
    "./use-keyboard-visible": {
      "import": "./dist/use-keyboard-visible.mjs",
      "require": "./dist/use-keyboard-visible.cjs"
    },
    "./use-memo-stable": {
      "import": "./dist/use-memo-stable.mjs",
      "require": "./dist/use-memo-stable.cjs"
    },
    "./use-network-state": {
      "import": "./dist/use-network-state.mjs",
      "require": "./dist/use-network-state.cjs"
    },
    "./use-previous": {
      "import": "./dist/use-previous.mjs",
      "require": "./dist/use-previous.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/async": "workspace:*",
    "@stryke/env": "workspace:*",
    "@stryke/type-checks": "workspace:*",
    "@stryke/types": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-native": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
