{
  "name": "@stryke/convert",
  "version": "0.7.20",
  "private": false,
  "description": "A utility package that helps convert between different data types.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/convert"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./array-buffer-to-string": {
      "import": "./dist/array-buffer-to-string.mjs",
      "require": "./dist/array-buffer-to-string.cjs"
    },
    "./buffer-to-string": {
      "import": "./dist/buffer-to-string.mjs",
      "require": "./dist/buffer-to-string.cjs"
    },
    "./extract-file-reference": {
      "import": "./dist/extract-file-reference.mjs",
      "require": "./dist/extract-file-reference.cjs"
    },
    "./neutral": {
      "import": "./dist/neutral.mjs",
      "require": "./dist/neutral.cjs"
    },
    "./string-to-buffer": {
      "import": "./dist/string-to-buffer.mjs",
      "require": "./dist/string-to-buffer.cjs"
    },
    "./string-to-uint8-array": {
      "import": "./dist/string-to-uint8-array.mjs",
      "require": "./dist/string-to-uint8-array.cjs"
    },
    "./string-to-utf8-array": {
      "import": "./dist/string-to-utf8-array.mjs",
      "require": "./dist/string-to-utf8-array.cjs"
    },
    "./to-array": {
      "import": "./dist/to-array.mjs",
      "require": "./dist/to-array.cjs"
    },
    "./to-bool": {
      "import": "./dist/to-bool.mjs",
      "require": "./dist/to-bool.cjs"
    },
    "./to-string-key": {
      "import": "./dist/to-string-key.mjs",
      "require": "./dist/to-string-key.cjs"
    },
    "./uint8-array-to-stream": {
      "import": "./dist/uint8-array-to-stream.mjs",
      "require": "./dist/uint8-array-to-stream.cjs"
    },
    "./uint8-array-to-string": {
      "import": "./dist/uint8-array-to-string.mjs",
      "require": "./dist/uint8-array-to-string.cjs"
    },
    "./uint8-array-to-string.node": {
      "import": "./dist/uint8-array-to-string.node.mjs",
      "require": "./dist/uint8-array-to-string.node.cjs"
    },
    "./utf8-array-to-string": {
      "import": "./dist/utf8-array-to-string.mjs",
      "require": "./dist/utf8-array-to-string.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/type-checks": "workspace:*",
    "@stryke/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
