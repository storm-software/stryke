{
  "name": "@stryke/unique-id",
  "version": "0.3.89",
  "private": false,
  "description": "A package containing various helper functions to generate unique identifier strings",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/unique-id"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cuid": {
      "import": "./dist/cuid.mjs",
      "require": "./dist/cuid.cjs"
    },
    "./human-id": {
      "import": "./dist/human-id.mjs",
      "require": "./dist/human-id.cjs"
    },
    "./nanoid": {
      "import": "./dist/nanoid.mjs",
      "require": "./dist/nanoid.cjs"
    },
    "./nanoid-client": {
      "import": "./dist/nanoid-client.mjs",
      "require": "./dist/nanoid-client.cjs"
    },
    "./random": {
      "import": "./dist/random.mjs",
      "require": "./dist/random.cjs"
    },
    "./snowflake": {
      "import": "./dist/snowflake.mjs",
      "require": "./dist/snowflake.cjs"
    },
    "./uuid": {
      "import": "./dist/uuid.mjs",
      "require": "./dist/uuid.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/hash": "workspace:*",
    "human-id": "catalog:"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
