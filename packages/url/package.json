{
  "name": "@stryke/url",
  "version": "0.4.28",
  "private": false,
  "description": "A package containing the `StormURL` class, which is used to parse and manipulate URLs.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/url"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./helpers": {
      "import": "./dist/helpers.mjs",
      "require": "./dist/helpers.cjs"
    },
    "./storm-url": {
      "import": "./dist/storm-url.mjs",
      "require": "./dist/storm-url.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./validate": {
      "import": "./dist/validate.mjs",
      "require": "./dist/validate.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/json": "workspace:*",
    "@stryke/path": "workspace:*",
    "@stryke/type-checks": "workspace:*",
    "ufo": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
