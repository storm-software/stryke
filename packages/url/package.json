{
  "name": "@stryke/resolve",
  "version": "0.0.1",
  "private": false,
  "description": "A package containing logic to resolve file contents from various sources.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/stryke.git",
    "directory": "packages/resolve"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./helpers": {
      "import": "./dist/helpers.mjs",
      "require": "./dist/helpers.cjs"
    },
    "./storm-url": {
      "import": "./dist/storm-url.mjs",
      "require": "./dist/storm-url.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./validate": {
      "import": "./dist/validate.mjs",
      "require": "./dist/validate.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "dependencies": {
    "@stryke/fs": "workspace:*",
    "@stryke/path": "workspace:*",
    "@stryke/type-checks": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
